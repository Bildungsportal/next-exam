{
  "name": "next-exam-teacher",
  "version": "1.99.0",
  "private": true,
  "main": "dist/main/main.mjs",
  "author": {
    "name": "Thomas Michael Weissel",
    "email": "valueerror@gmail.com",
    "url": "https://next-exam.at"
  },
  "homepage": "https://next-exam.at",
  "license": "GPL-3.0",
  "description": "An exam managment tool for digital exams",
  "type": "module",
  "scripts": {
    "dev:quasar": "quasar dev",
    "build:quasar": "quasar build",
    "postinstall": "patch-package && quasar prepare",
    "dev": " npm run prebuild && quasar dev --verbose -m electron",
    "build": "quasar build --verbose -m electron",
    "clean": "rm -rf ./dist",
    "cleanwin": "if exist dist rmdir /s /q dist",
    "prebuild": "node scripts/prebuild.js",
    "protect:main": "node scripts/protect-main.mjs",
    "build:linux": "npm run prebuild && npm run clean && quasar build --verbose -m electron -l",
    "build:mac:x64": "npm run prebuild && npm run clean && cross-env NXE_EB_MAC_ARCH=x64 quasar build --verbose -m electron -T mac -A x64",
    "build:mac:arm64": "npm run prebuild && npm run clean && cross-env NXE_EB_MAC_ARCH=arm64 quasar build --verbose -m electron -T mac -A arm64",
    "build:win:portable": "npm run prebuild && npm run cleanwin && quasar build --verbose -m electron -T win -A x64",
    "build:win:msi": "npm run prebuild && npm run cleanwin && cross-env NXE_EB_WIN_TARGET=msi quasar build --verbose -m electron -T win -A x64"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@quasar/app-vite": "^2.6.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/plist": "^3.0.5",
    "@types/screenshot-desktop": "^1.15.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/devtools": "^8.1.1",
    "concurrently": "^9.2.1",
    "electron": "41.7.0",
    "electron-builder": "26.11.0",
    "electron-devtools-installer": "^4.0.0",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.1",
    "nodemon": "^3.1.14",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-resolve": "^2.5.2",
    "vue": "^3.5.33"
  },
  "env": {
    "//": "Used in build scripts",
    "PORT": 3002
  },
  "keywords": [
    "vite",
    "electron",
    "vue3",
    "rollup"
  ],
  "dependencies": {
    "@azure/msal-browser": "^5.8.0",
    "@azure/msal-node": "^5.1.4",
    "@bingsjs/pdf-parse": "^1.1.1",
    "@electron/notarize": "^3.1.1",
    "@quasar/extras": "^1.18.0",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "als-diskinfo": "^0.1.1",
    "archiver": "^7.0.1",
    "bootstrap": "^5.3.8",
    "bytenode": "^1.5.7",
    "chalk": "^5.6.2",
    "check-disk-space": "^3.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "default-gateway": "^7.2.2",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-vite": "^5.0.0",
    "express": "^4.22.1",
    "express-easy-zip": "^1.1.5",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.3.2",
    "extract-zip": "^2.0.1",
    "ip": "^2.0.1",
    "lowlight": "^3.3.0",
    "moment": "^2.30.1",
    "node-forge": "^1.4.0",
    "os": "^0.1.2",
    "patch-package": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-signature-reader": "^1.4.3",
    "pdf-to-printer": "^5.7.0",
    "pdfjs-dist": "^5.6.205",
    "pino-pretty": "^13.1.3",
    "plist": "^3.1.0",
    "psl": "^1.15.0",
    "qs": "^6.15.1",
    "screenshot-desktop": "^1.15.4",
    "sortablejs": "^1.15.7",
    "terser": "^5.46.1",
    "uuid": "^11.1.1",
    "vue": "^3.5.33",
    "vue-draggable-next": "^2.3.0",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.6",
    "vue-sweetalert2": "^5.0.11"
  },
  "overrides": {
    "@parcel/watcher": "npm:@favware/skip-dependency@1.2.2"
  },
  "buildNumber": "0",
  "buildVersion": "1.99.0.0"
}
