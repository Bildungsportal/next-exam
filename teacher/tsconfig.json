{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "importHelpers": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": "./",
    "paths": {},
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    // Disable everything for now to just get tooltips and not everything marked red
    "strict": false,
    "noCheck": true
  }
}


