# Version & build (used by prebuild and quasar.config.ts)
VERSION=1.99.0
BUILD_NUMBER=0
PRODUCT_NAME="Next-Exam-Student"
INFO="Development"

# App / client
CLIENT_DIRECTORY="EXAM-STUDENT"
SERVER_API_PORT=22422
MULTICAST_CLIENT_PORT=6024

# Features
USE_BUNDLED_JRE=true
BIP_INTEGRATION=true
BIP_DEMO=true
BIP_API_URL="https://localhost:8444"
IS_PUAVO=false

# Build options
OBFUSCATE_MAIN=true
SIGN=true
# macOS: false = sign only (local); true = notarytool + stapler (required for normal launch on macOS 26+)
NOTARIZE=false
# CSC_NAME: ohne "Developer ID Application:" (electron-builder); SHAID: voller Name aus `security find-identity`
# CSC_NAME="Thomas Weissel (TEAMID)"
# SHAID="Developer ID Application: Thomas Weissel (TEAMID)"
SHOWDEVTOOLS=true
DEVELOPMENT=true

